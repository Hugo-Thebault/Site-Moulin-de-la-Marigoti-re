# Activer le moteur de réécriture
RewriteEngine On

# Si le fichier ou dossier demandé existe physiquement, le servir directement
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Laisser les requêtes API être traitées par PHP
RewriteRule ^api/ - [L]

# Toutes les autres requêtes sont redirigées vers index.html (SPA React)
RewriteRule ^ index.html [L]
